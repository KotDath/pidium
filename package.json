		"lint:fix": "biome check --fix ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@earendil-works/pi-coding-agent": "^0.80.3",
		"@earendil-works/pi-tui": "^0.80.3",
		"typescript": "^5.7.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
