{
	"name": "pidium",
	"private": true,
	"packageManager": "pnpm@10.33.0",
	"workspaces": ["packages/*"],
	"pi": {
		"extensions": ["./packages/pidium-themes/index.ts"]
	},
	"scripts": {
		"typecheck": "pnpm -r run typecheck",
