{
	"name": "@pidium/web",
	"version": "0.1.0",
	"private": true,
	"description": "Keyless web search and content fetching extension for pi",
	"type": "module",
	"keywords": ["pi-package", "pi", "web-search", "web-fetch"],
	"pi": {
		"extensions": ["./index.ts"]
	},
	"files": ["index.ts", "lib/**/*.ts", "tools/**/*.ts", "README.md", "!**/*.test.ts"],
	"scripts": {
		"test": "vitest run",
		"typecheck": "tsc --project ./tsconfig.json --noEmit"
	},
	"peerDependencies": {
		"@earendil-works/pi-agent-core": ">=0.80.0",
		"@earendil-works/pi-ai": ">=0.80.0",
		"@earendil-works/pi-coding-agent": ">=0.80.0",
		"@earendil-works/pi-tui": ">=0.80.0",
		"typebox": "*"
	},
	"dependencies": {
		"@mozilla/readability": "^0.6.0",
		"linkedom": "^0.18.12",
		"turndown": "^7.2.2"
	},
	"devDependencies": {
		"@types/turndown": "^5.0.5"
	}
}
